{
    "$schema": "http://json.schemastore.org/template",
    "author": "Ing Ramon Montoya R",
    "defaultName": "rmReactViteApp",
    "repository": {
        "url": "https://github.com/",
        "type": "GitHub"
    },
    "projectURL": "https://github.com/",
    "releaseNotes": "Template for ReactJS with TypeScript, TailwindCSS, and Vite.",
    "classifications": ["Web", "React", "TypeScript", "TailwindCSS", "Vite"],
    "identity": "rmr.ReactJS.Ts.TailwindCSS.Template",
    "name": "rmReactJS_Ts_TailwindCSS_Template",
    "shortName": "rm-react-ts",
    "sourceName": "rmReactJS_Ts_TailwindCSS",
    "tags": {
        "language": "TypeScript",
        "type": "project"
    },
    "preferNameDirectory": true,
    "primaryOutputs": [
        { "path": "rmreactjs_ts_tailwindcss.esproj" }
    ],
    "symbols": {
        "RootNamespace": {
            "type": "parameter",
            "defaultValue": "rmReactJS_Ts_TailwindCSS",
            "replaces": "rmReactJS_Ts_TailwindCSS"
        }
    }
}
